# 모델 입력 해상도
MODEL_W=512
MODEL_H=384
TARGET_W=512
TARGET_H=384

# 배치 및 전처리 설정
BATCH_SIZE=1           # CPU 1코어 플랜은 1이 가장 안전
PREPROC_THREADS=1
FAST_PREVIEW=1

# 업로드 제한
MAX_FILES=8
MAX_BYTES=4194304

# 비디오 생성
VIDEO_FPS=8
INFER_EVERY_N_FRAMES=10

# YOLO 비디오 추론
FRAME_STRIDE=4             # 2 또는 3 권장 (매 2~3프레임만 실제 탐지)
VIDEO_INFER_SIZE=512       # 512~640 권장 (CPU면 512 더 빠름)

# 스크롤 동영상 생성 파라미터
SCROLL_FPS=8             # 10~12 권장
SECONDS_PER_TILE=0.7      # 0.8~1.2 권장

# 스크롤 모드
SCROLL_MODE=1
TWO_PASS_DETECT=0          # ← 핵심! 프레임별 재검출 금지     
USE_FFMPEG=0               # 선택: ffmpeg 파이프 이슈면 0으로 (OpenCV writer 사용)
SHOW_LABELS=0             # 너무 느리면 0으로 잠깐 꺼도 됨(라벨 렌더 비용 제거)

